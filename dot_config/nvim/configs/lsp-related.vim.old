" === Autocmds for Formatting ===
" Format Go on save
autocmd BufWritePre *.go lua vim.lsp.buf.format({ async = false })

" Format Fish on save using fish_indent
autocmd BufWritePre *.fish silent! execute '%!fish_indent'

" Detect Bash shebangs
autocmd BufRead,BufNewFile * if getline(1) =~# '^#!.*\<\(bash\|sh\)\>' | set filetype=sh | endif

" Format Python on save (isort + black)
autocmd BufWritePre *.py lua vim.lsp.buf.format({ async = false })

" Format CSS/SCSS/SASS on save with Prettier
autocmd BufWritePre *.css,*.scss,*.sass lua vim.lsp.buf.format({ async = false })

" === LSP and Formatter Setup ===
lua << EOF
-- Set up mason for installing LSPs and formatters
require("mason").setup()
require("mason-lspconfig").setup({
  ensure_installed = {
    "pyright",
    "gopls",
    "ts_ls",
    "bashls",
    "html",
    "rust_analyzer",
    "intelephense"
  },
})

local lspconfig = require("lspconfig")

-- Function for setting up keymaps for each buffer
local on_attach = function(_, bufnr)
  local buf_map = function(mode, lhs, rhs)
    vim.api.nvim_buf_set_keymap(bufnr, mode, lhs, rhs, { noremap = true, silent = true })
  end
  buf_map("n", "gd", "<cmd>lua vim.lsp.buf.definition()<CR>")
  buf_map("n", "K", "<cmd>lua vim.lsp.buf.hover()<CR>")
end

-- Set up each language server
for _, server in ipairs({ "pyright", "gopls", "ts_ls", "bashls", "html", "rust_analyzer", "intelephense" }) do
  lspconfig[server].setup({ on_attach = on_attach })
end

-- === LSP Configuration for Specific Servers ===
local lspconfig = require('lspconfig')

lspconfig.intelephense.setup({
  on_attach = on_attach,
  
  -- Use absolute paths. $HOME will NOT work.
  init_options = {
    globalStoragePath = os.getenv("HOME") .. "/.cache/intelephense",
    storagePath = "/tmp/intelephense",
    -- Optional: If you have a license key, put it here to stop it 
    -- from looking for a 'licence.txt' in ~/intelephense
    -- licenceKey = "YOUR_KEY", 
  },

  -- Custom Root Directory Logic
  root_dir = function(pattern)
    local util = require('lspconfig.util')
    local fallback = vim.loop.cwd()
    -- Look for WordPress specific markers first, then standard PHP markers
    return util.root_pattern("wp-config.php", "composer.json", ".git")(pattern) or fallback
  end,

  settings = {
    intelephense = {
      stubs = {
        "apache", "bcmath", "bz2", "calendar", "Core", "curl", "date", "dom", "filter", "gd", 
        "hash", "iconv", "imap", "json", "libxml", "mbstring", "mysqli", "openssl", "pcre", 
        "PDO", "pdo_mysql", "Phar", "readline", "SimpleXML", "soap", "sockets", "sqlite3", 
        "standard", "tokenizer", "xml", "xmlreader", "xmlwriter", "zip", "zlib",
        "wordpress", -- This enables the built-in WP stubs
      },
      files = {
        maxSize = 1000000,
        associations = { "*.php", "*.inc" },
      },
      environment = {
        -- This is where you point to your custom stubs folder
        includePaths = { "/Users/Jon/.config/nvim/stubs" }
      },
      diagnostics = {
        enable = true,
      },
    },
  },
})
-- Example: gopls setup with initialization options
lspconfig.gopls.setup({
  on_attach = on_attach,
  settings = {
    gopls = {
      formatOnSave = true,
      usePlaceholders = true,
      completeUnimported = true,
    },
  },
})

-- Example: pyright setup with additional settings for formatting
lspconfig.pyright.setup({
  on_attach = on_attach,
  cmd = { "/Users/Jon/.local/share/nvim/mason/bin/pyright-langserver", "--stdio" },
  settings = {
    python = {
      formatting = {
        provider = "ruff",
      },
      linting = {
        enabled = true,
        ruffEnabled = true,
      },
      sortImports = "ruff",
      ruffArgs = { "--disable-rule=E302" },
    },
  },
})

-- === Null-ls Setup (Formatters and Linters) ===
local null_ls = require("null-ls")
null_ls.setup({
  sources = {
    -- Formatters
    null_ls.builtins.formatting.black,
    null_ls.builtins.formatting.isort,
    null_ls.builtins.formatting.prettier,
    -- You can add more formatters/linters here
    -- Example: linters
  },
  on_attach = on_attach,
})
EOF


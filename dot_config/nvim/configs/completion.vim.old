set completeopt=menuone

lua <<EOF
-- completion.vim

-- Set up nvim-cmp
local cmp = require('cmp')

cmp.setup({
  snippet = {
    expand = function(args)
      vim.snippet.expand(args.body)
      -- Choose the snippet engine you're using, here we use vsnip
      vim.fn["vsnip#anonymous"](args.body)  -- For vsnip
      -- require('luasnip').lsp_expand(args.body) -- For luasnip users
    end,
  },
  window = {
    -- Enable borders for completion and documentation windows if needed
    completion = cmp.config.window.bordered(),
    documentation = cmp.config.window.bordered(),
  },
  mapping = cmp.mapping.preset.insert({
    ['<C-b>'] = cmp.mapping.scroll_docs(-4),
    ['<C-f>'] = cmp.mapping.scroll_docs(4),
    ['<C-Space>'] = cmp.mapping.complete(),
    ['<C-e>'] = cmp.mapping.abort(),
    ['<CR>'] = cmp.mapping.confirm({ select = true }),  -- Confirm selection
  }),
  sources = cmp.config.sources({
    { name = 'nvim_lsp' },
    { name = 'path' },
    { name = 'luasnip' }, -- Uncomment for luasnip
  }, {
    { name = 'buffer' },
  }),
  experimental = {
    -- Enable experimental features to complete file paths and file names.
    native_menu = false, -- Disable native menu for path completion (Vim style)
  },
})

-- Set up LSP
local capabilities = require('cmp_nvim_lsp').default_capabilities()

-- Set up LSP servers
require('lspconfig').pyright.setup{
  capabilities = capabilities
}
require('lspconfig').gopls.setup{
  capabilities = capabilities
}
require('lspconfig').ts_ls.setup{
  capabilities = capabilities
}
require('lspconfig').bashls.setup{
  capabilities = capabilities
}
require('lspconfig').intelephense.setup{
  capabilities = capabilities
}
EOF
